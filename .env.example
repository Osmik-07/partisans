# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789

# Pyrogram (MTProto) — получить на my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
USERBOT_SESSION_SECRET=replace_with_long_random_secret

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=notspybot
DB_USER=notspybot
DB_PASS=strongpassword

# Redis
REDIS_URL=redis://redis:6379/0

# CryptoBot
CRYPTOBOT_TOKEN=your_cryptobot_token
CRYPTOBOT_WEBHOOK_SECRET=your_secret_string

# Webhook (оставь пустым для polling-режима)
WEBHOOK_HOST=
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8443

# Цены подписок (USD)
PRICE_TRIAL_DAYS=3
PRICE_WEEK_USD=1.50
PRICE_MONTH_USD=3.00
PRICE_YEAR_USD=15.00

# Telegram Stars
PRICE_WEEK_STARS=75
PRICE_MONTH_STARS=150
PRICE_YEAR_STARS=750
# Mini App
MINIAPP_DOMAIN=traceapp.ru
